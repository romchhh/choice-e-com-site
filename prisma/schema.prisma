// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   // For email/password auth
  phone         String?
  address       String?   // Delivery address (city, post office)
  clothingSize  String?   @map("clothing_size")
  birthDate     DateTime? @map("birth_date")
  bonusPoints   Int       @default(0) @map("bonus_points")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  wishlist      Wishlist[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
  @@map("wishlist")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String?   @unique // ЧПУ: англ. транскрипція назви (nullable для існуючих записів до backfill)
  priority    Int       @default(0)
  mediaType   String?   @map("media_type") // "photo" or "video"
  mediaUrl    String?   @map("media_url")
  products    Product[]
  productLinks ProductCategoryLink[]
  subcategories Subcategory[]
  
  @@map("categories")
}

model Subcategory {
  id         Int      @id @default(autoincrement())
  name       String
  slug       String?  @unique // ЧПУ для URL
  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]
  productLinks ProductSubcategoryLink[]

  @@map("subcategories")
}

model Product {
  id                   Int            @id @default(autoincrement())
  name                 String
  slug                 String?        @unique
  subtitle             String?        @map("subtitle")
  releaseForm          String?        @map("release_form")  // Форма випуску, напр. "30 саше по 2 г"
  course               String?        // Курс, напр. "30 днів"
  packageWeight        String?        @map("package_weight") // Вага упаковки, напр. "60 г"
  mainInfo             String?        @map("main_info") @db.Text
  shortDescription     String?        @map("short_description") @db.Text
  description          String?        @db.Text // Повний опис
  mainAction           String?        @map("main_action") @db.Text
  indicationsForUse    String?        @map("indications_for_use") @db.Text
  benefits             String?        @db.Text
  fullComposition      String?        @map("full_composition") @db.Text
  usageMethod          String?        @map("usage_method") @db.Text
  contraindications    String?       @db.Text
  storageConditions    String?        @map("storage_conditions") @db.Text
  price                Decimal        @db.Decimal(10, 2)
  oldPrice             Decimal?       @map("old_price") @db.Decimal(10, 2)
  discountPercentage   Int?           @map("discount_percentage")
  priority             Int            @default(0)
  topSale              Boolean        @default(false) @map("top_sale")
  inStock              Boolean        @default(true) @map("in_stock")
  limitedEdition       Boolean        @default(false) @map("limited_edition")
  season               String[]       @default([])
  stock                Int            @default(0)
  categoryId           Int?           @map("category_id")
  subcategoryId        Int?           @map("subcategory_id")
  fabricComposition    String?        @map("fabric_composition") @db.Text
  hasLining            Boolean        @default(false) @map("has_lining")
  liningDescription    String?        @map("lining_description") @db.Text
  createdAt            DateTime       @default(now()) @map("created_at")

  category             Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory          Subcategory?   @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  media                ProductMedia[]
  orderItems           OrderItem[]
  wishlistedBy         Wishlist[]
  categoryLinks        ProductCategoryLink[]
  subcategoryLinks     ProductSubcategoryLink[]

  @@map("products")
}

model ProductCategoryLink {
  productId Int
  categoryId Int

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_category_links")
}

model ProductSubcategoryLink {
  productId    Int
  subcategoryId Int

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  subcategory Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@id([productId, subcategoryId])
  @@map("product_subcategory_links")
}

model ProductMedia {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  type      String  // "photo" or "video"
  url       String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@map("product_media")
}

model PromoCode {
  id          Int       @id @default(autoincrement())
  code        String    @unique // код для введення (наприклад SALE10)
  type        String    // "percent" | "fixed"
  value       Decimal   @db.Decimal(10, 2) // % або сума в грн
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  maxUses     Int?      @map("max_uses") // null = необмежено
  usedCount   Int       @default(0) @map("used_count")
  createdAt   DateTime  @default(now()) @map("created_at")

  orders      Order[]

  @@map("promo_codes")
}

model Order {
  id            Int         @id @default(autoincrement())
  userId        String?     @map("user_id")
  customerName  String      @map("customer_name")
  phoneNumber   String      @map("phone_number")
  email         String?
  deliveryMethod String     @map("delivery_method")
  city          String
  postOffice    String      @map("post_office")
  comment       String?
  paymentType   String      @map("payment_type") // "prepay" or "full"
  invoiceId     String      @unique @map("invoice_id")
  paymentStatus String      @default("pending") @map("payment_status") // "pending" | "paid" | "canceled"
  bonusPointsSpent Int      @default(0) @map("bonus_points_spent") // скільки бонусів списано при оформленні
  loyaltyDiscountAmount Decimal? @map("loyalty_discount_amount") @db.Decimal(10, 2) // знижка по програмі лояльності (грн)
  promoCodeId  Int?        @map("promo_code_id")
  promoDiscountAmount Decimal? @map("promo_discount_amount") @db.Decimal(10, 2) // знижка по промокоду (грн)
  status       String?     // Optional status field
  createdAt    DateTime    @default(now()) @map("created_at")
  
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  promoCode    PromoCode?  @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  
  @@map("orders")
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  productId   Int?     @map("product_id")
  productName String? @map("product_name") // збережена назва товару на момент замовлення (не залежить від видалення товару)
  size        String
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  color       String?

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model NewsletterCampaign {
  id        String   @id @default(cuid())
  subject   String   @db.Text
  body      String   @db.Text
  isHtml    Boolean  @default(false) @map("is_html")
  sentCount Int      @default(0) @map("sent_count")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_campaigns")
}
